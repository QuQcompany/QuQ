<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>QuQ — Coming Soon</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --blue-deep:    #020b18;
      --blue-dark:    #040f22;
      --blue-mid:     #0a2550;
      --blue-bright:  #1565c0;
      --blue-neon:    #29b6f6;
      --blue-glow:    #40c4ff;
      --cyan-spark:   #00e5ff;
      --white:        #e8f4ff;
      --muted:        #6b9ec4;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      background: var(--blue-deep);
      color: var(--white);
      font-family: 'Rajdhani', sans-serif;
      overflow-x: hidden;
    }

    canvas#stars {
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }

    .grid-overlay {
      position: fixed;
      inset: 0;
      z-index: 0;
      background-image:
        linear-gradient(rgba(41,182,246,.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(41,182,246,.04) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
      animation: gridPulse 8s ease-in-out infinite;
    }
    @keyframes gridPulse {
      0%, 100% { opacity: .5; }
      50%       { opacity: 1; }
    }

    .blob {
      position: fixed;
      border-radius: 50%;
      filter: blur(90px);
      opacity: .18;
      pointer-events: none;
      z-index: 0;
      animation: blobFloat 12s ease-in-out infinite alternate;
    }
    .blob1 { width: 600px; height: 600px; background: #0d47a1; top: -200px; left: -200px; }
    .blob2 { width: 500px; height: 500px; background: #01579b; bottom: -150px; right: -150px; animation-delay: -4s; }
    .blob3 { width: 350px; height: 350px; background: #00acc1; top: 40%; left: 55%; animation-delay: -8s; }
    @keyframes blobFloat {
      from { transform: translate(0,0) scale(1); }
      to   { transform: translate(30px,20px) scale(1.05); }
    }

    .page {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 48px 24px;
    }

    .logo-icon {
      width: 88px; height: 88px;
      background: linear-gradient(135deg, var(--blue-mid), var(--blue-bright));
      border: 2px solid var(--blue-neon);
      border-radius: 22px;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Orbitron', monospace;
      font-size: 2rem; font-weight: 900;
      color: var(--cyan-spark);
      box-shadow: 0 0 32px rgba(41,182,246,.4), inset 0 0 20px rgba(41,182,246,.1);
      margin-bottom: 16px;
      animation: fadeDown .9s cubic-bezier(.22,1,.36,1) both, iconPulse 3s 1s ease-in-out infinite;
    }
    @keyframes iconPulse {
      0%, 100% { box-shadow: 0 0 32px rgba(41,182,246,.4), inset 0 0 20px rgba(41,182,246,.1); }
      50%       { box-shadow: 0 0 60px rgba(41,182,246,.7), inset 0 0 30px rgba(41,182,246,.2); }
    }

    h1 {
      font-family: 'Orbitron', monospace;
      font-size: clamp(2.8rem, 8vw, 5.5rem);
      font-weight: 900;
      letter-spacing: .05em;
      text-align: center;
      line-height: 1;
      background: linear-gradient(135deg, var(--white) 30%, var(--cyan-spark));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: fadeDown .9s .1s cubic-bezier(.22,1,.36,1) both;
    }

    .tagline {
      font-size: clamp(1rem, 2.5vw, 1.3rem);
      font-weight: 300;
      color: var(--blue-neon);
      letter-spacing: .2em;
      text-transform: uppercase;
      text-align: center;
      margin-top: 10px;
      animation: fadeDown .9s .2s cubic-bezier(.22,1,.36,1) both;
    }

    .divider {
      width: 180px; height: 2px;
      background: linear-gradient(90deg, transparent, var(--blue-neon), transparent);
      margin: 28px 0;
      animation: fadeIn .9s .3s both;
    }

    .desc {
      max-width: 560px;
      text-align: center;
      font-size: 1.1rem;
      color: var(--muted);
      line-height: 1.7;
      animation: fadeIn .9s .4s both;
    }
    .desc strong { color: var(--white); }

    .badges {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: center;
      margin-top: 24px;
      animation: fadeIn .9s .5s both;
    }
    .badge {
      padding: 5px 14px;
      border-radius: 100px;
      font-size: .78rem;
      font-weight: 600;
      letter-spacing: .12em;
      text-transform: uppercase;
      border: 1px solid;
    }
    .badge-bug  { border-color: #ef5350; color: #ef5350; background: rgba(239,83,80,.08); }
    .badge-p2w  { border-color: #ffa726; color: #ffa726; background: rgba(255,167,38,.08); }
    .badge-mc   { border-color: var(--blue-neon); color: var(--blue-neon); background: rgba(41,182,246,.08); }
    .badge-eula { border-color: var(--cyan-spark); color: var(--cyan-spark); background: rgba(0,229,255,.08); }

    .soon-card {
      margin-top: 40px;
      background: rgba(10,37,80,.5);
      border: 1px solid rgba(41,182,246,.2);
      border-radius: 20px;
      padding: 36px 40px;
      max-width: 520px;
      width: 100%;
      backdrop-filter: blur(14px);
      box-shadow: 0 8px 48px rgba(0,0,0,.5), 0 0 0 1px rgba(41,182,246,.08);
      animation: fadeUp .9s .5s cubic-bezier(.22,1,.36,1) both;
    }

    .soon-label {
      font-family: 'Orbitron', monospace;
      font-size: .7rem;
      letter-spacing: .25em;
      color: var(--cyan-spark);
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .blink-cursor::after {
      content: '|';
      animation: blink 1s step-end infinite;
      margin-left: 2px;
      color: var(--cyan-spark);
    }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

    .soon-title {
      font-family: 'Orbitron', monospace;
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 6px;
    }

    .soon-sub {
      font-size: 1rem;
      color: var(--muted);
      margin-bottom: 28px;
    }

    .email-label {
      font-size: .85rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--blue-neon);
      margin-bottom: 10px;
      display: block;
    }

    .email-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .email-row input[type="email"] {
      flex: 1;
      min-width: 180px;
      background: rgba(4,15,34,.7);
      border: 1px solid rgba(41,182,246,.35);
      border-radius: 10px;
      padding: 12px 16px;
      font-family: 'Rajdhani', sans-serif;
      font-size: 1rem;
      color: var(--white);
      outline: none;
      transition: border-color .25s, box-shadow .25s;
    }
    .email-row input[type="email"]::placeholder { color: var(--muted); }
    .email-row input[type="email"]:focus {
      border-color: var(--blue-neon);
      box-shadow: 0 0 0 3px rgba(41,182,246,.15);
    }

    .btn-notify {
      background: linear-gradient(135deg, var(--blue-bright), #0288d1);
      border: none;
      border-radius: 10px;
      padding: 12px 22px;
      font-family: 'Orbitron', monospace;
      font-size: .78rem;
      font-weight: 700;
      letter-spacing: .12em;
      color: #fff;
      cursor: pointer;
      transition: transform .15s, box-shadow .2s;
      box-shadow: 0 4px 20px rgba(21,101,192,.5);
      white-space: nowrap;
    }
    .btn-notify:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 28px rgba(21,101,192,.65);
    }
    .btn-notify:active { transform: translateY(0); }

    .success-msg {
      display: none;
      margin-top: 12px;
      font-size: .95rem;
      color: #69f0ae;
      letter-spacing: .05em;
    }

    .discord-btn {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 18px;
      background: rgba(88,101,242,.15);
      border: 1px solid rgba(88,101,242,.45);
      border-radius: 12px;
      padding: 13px 20px;
      text-decoration: none;
      color: #c3c8ff;
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: .05em;
      transition: background .2s, border-color .2s, transform .15s;
    }
    .discord-btn:hover {
      background: rgba(88,101,242,.28);
      border-color: rgba(88,101,242,.8);
      transform: translateY(-2px);
      color: #fff;
    }

    .eula-notice {
      margin-top: 36px;
      max-width: 520px;
      width: 100%;
      background: rgba(2,11,24,.55);
      border: 1px solid rgba(41,182,246,.12);
      border-left: 3px solid var(--blue-neon);
      border-radius: 10px;
      padding: 16px 20px;
      font-size: .82rem;
      color: var(--muted);
      line-height: 1.6;
      animation: fadeIn 1s .7s both;
    }
    .eula-notice a { color: var(--blue-neon); text-decoration: none; }
    .eula-notice a:hover { text-decoration: underline; }
    .eula-notice strong { color: var(--white); }

    footer {
      margin-top: 36px;
      font-size: .78rem;
      color: rgba(107,158,196,.5);
      text-align: center;
      letter-spacing: .12em;
      animation: fadeIn 1s .8s both;
    }
    footer a { color: var(--blue-neon); text-decoration: none; opacity: .7; }
    footer a:hover { opacity: 1; }

    .scanline {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--cyan-spark), transparent);
      opacity: .25;
      animation: scanDown 6s linear infinite;
      pointer-events: none;
      z-index: 10;
    }
    @keyframes scanDown {
      from { top: -2px; }
      to   { top: 100vh; }
    }

    @keyframes fadeDown {
      from { opacity: 0; transform: translateY(-24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    @media (max-width: 480px) {
      .soon-card { padding: 28px 22px; }
      .email-row { flex-direction: column; }
      .btn-notify { width: 100%; text-align: center; }
    }
  </style>
</head>
<body>

  <canvas id="stars"></canvas>
  <div class="grid-overlay"></div>
  <div class="blob blob1"></div>
  <div class="blob blob2"></div>
  <div class="blob blob3"></div>
  <div class="scanline"></div>

  <div class="page">

    <div class="logo-icon">QuQ</div>

    <h1>QuQ</h1>
    <p class="tagline">Minecraft Bug &amp; P2W Hunter Community</p>

    <div class="divider"></div>

    <p class="desc">
      We hunt <strong>pay-to-win servers</strong>, expose <strong>EULA violations</strong>,
      and protect players from <strong>gambling mechanics</strong> — keeping Minecraft
      fair and safe for everyone.
    </p>

    <div class="badges">
      <span class="badge badge-bug">🐛 Bug Reports</span>
      <span class="badge badge-p2w">💰 P2W Exposure</span>
      <span class="badge badge-mc">⛏ Minecraft</span>
      <span class="badge badge-eula">📜 EULA Watchdog</span>
    </div>

    <div class="soon-card">
      <div class="soon-label">// STATUS</div>
      <div class="soon-title blink-cursor">Coming Soon</div>
      <p class="soon-sub">Please wait — something big is loading…</p>

      <label class="email-label" for="emailInput">📬 Get notified via Gmail</label>
      <div class="email-row">
        <input type="email" id="emailInput" placeholder="you@gmail.com" autocomplete="email" />
        <button class="btn-notify" onclick="handleNotify()">NOTIFY ME</button>
      </div>
      <div class="success-msg" id="successMsg">✅ You're on the list! We'll reach out soon.</div>

      <a class="discord-btn" href="https://discord.gg/WcYST9qCda" target="_blank" rel="noopener">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="#7289da" xmlns="http://www.w3.org/2000/svg">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
        </svg>
        Join our Discord — discord.gg/WcYST9qCda
      </a>
    </div>

    <div class="eula-notice">
      <strong>📜 Our Mission &amp; Minecraft EULA:</strong> QuQ operates in accordance with
      <a href="https://www.minecraft.net/pt-br/usage-guidelines" target="_blank" rel="noopener">Minecraft's Usage Guidelines</a>
      and the Microsoft Services Agreement. We do not distribute or commercially exploit Mojang's
      intellectual property. We exist to report servers that violate these rules — especially
      those enabling gambling mechanics and unfair pay-to-win advantages — helping keep
      Minecraft safe and fair for all players.
    </div>

    <footer>
      &copy; 2025 QuQ Community &nbsp;·&nbsp;
      <a href="https://discord.gg/WcYST9qCda" target="_blank" rel="noopener">Discord</a>
      &nbsp;·&nbsp;
      <a href="https://www.minecraft.net/pt-br/usage-guidelines" target="_blank" rel="noopener">MC Guidelines</a>
    </footer>

  </div>

  <script>
    const canvas = document.getElementById('stars');
    const ctx = canvas.getContext('2d');
    let stars = [];

    function resize() {
      canvas.width  = window.innerWidth;
      canvas.height = window.innerHeight;
    }

    function initStars() {
      stars = [];
      const count = Math.floor((canvas.width * canvas.height) / 6000);
      for (let i = 0; i < count; i++) {
        stars.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          r: Math.random() * 1.4 + .2,
          alpha: Math.random(),
          speed: Math.random() * .004 + .001,
          phase: Math.random() * Math.PI * 2
        });
      }
    }

    function drawStars(t) {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      stars.forEach(s => {
        const a = .2 + .8 * Math.abs(Math.sin(s.phase + t * s.speed));
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(144,213,255,${a * s.alpha})`;
        ctx.fill();
      });
    }

    function loop(t) {
      drawStars(t * .001);
      requestAnimationFrame(loop);
    }

    window.addEventListener('resize', () => { resize(); initStars(); });
    resize(); initStars(); requestAnimationFrame(loop);

    function handleNotify() {
      const input = document.getElementById('emailInput');
      const msg   = document.getElementById('successMsg');
      const email = input.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        input.style.borderColor = '#ef5350';
        input.focus();
        setTimeout(() => input.style.borderColor = '', 1500);
        return;
      }
      const subject = encodeURIComponent('QuQ — Notify Me When Live');
      const body    = encodeURIComponent(
        `Hi QuQ team,\n\nPlease add me to the notification list!\n\nEmail: ${email}\n\nLooking forward to joining the community!`
      );
      window.open(
        `https://mail.google.com/mail/?view=cm&to=quqcommunity@gmail.com&su=${subject}&body=${body}`,
        '_blank'
      );
      msg.style.display = 'block';
      input.value = '';
    }

    document.getElementById('emailInput').addEventListener('keydown', e => {
      if (e.key === 'Enter') handleNotify();
    });
  </script>
</body>
</html>
